Panels:
- Class: rviz_common/Displays
  Help Height: 70
  Name: Displays
  Property Tree Widget:
    Expanded:
    - /Global Options1
    - /Navigation Reference1
    - /Raw Boat LaserScan1
    - /Boat Laser Range1
    - /Boat Goal1
    Splitter Ratio: 0.5
  Tree Height: 225
- Class: rviz_common/Views
  Expanded:
  - /Current View1
  Name: Views
  Splitter Ratio: 0.5
Visualization Manager:
  Class: ''
  Displays:
  - Alpha: 0.44999998807907104
    Cell Size: 5
    Class: rviz_default_plugins/Grid
    Color: 120; 145; 155
    Enabled: true
    Line Style:
      Line Width: 0.029999999329447746
      Value: Lines
    Name: World Grid
    Normal Cell Count: 0
    Offset:
      X: 0
      Y: 0
      Z: 0
    Plane: XY
    Plane Cell Count: 40
    Reference Frame: <Fixed Frame>
    Value: true
  - Class: rviz_default_plugins/MarkerArray
    Enabled: true
    Name: Navigation Reference
    Namespaces:
      boat: true
      boat_label: true
      buoy_labels: true
      buoys: true
      goal: true
      goal_label: true
      lighthouse: true
      lighthouse_label: true
      navigation_area: true
    Topic:
      Depth: 5
      Durability Policy: Volatile
      History Policy: Keep Last
      Reliability Policy: Reliable
      Value: /boat/navigation_markers
    Value: true
  - Alpha: 1
    Autocompute Intensity Bounds: true
    Autocompute Value Bounds: &id001
      Max Value: 10
      Min Value: -10
      Value: true
    Axis: Z
    Channel Name: intensity
    Class: rviz_default_plugins/LaserScan
    Color: 0; 229; 255
    Color Transformer: FlatColor
    Decay Time: 0
    Enabled: true
    Invert Rainbow: false
    Max Color: 255; 255; 255
    Max Intensity: 4096
    Min Color: 0; 0; 0
    Min Intensity: 0
    Name: Raw Boat LaserScan
    Position Transformer: XYZ
    Selectable: true
    Size (Pixels): 3
    Size (m): 0.35
    Style: Spheres
    Topic:
      Depth: 5
      Durability Policy: Volatile
      Filter size: 10
      History Policy: Keep Last
      Reliability Policy: Reliable
      Value: /boat/scan
    Use Fixed Frame: true
    Use rainbow: true
    Value: true
  - Alpha: 0.32
    Autocompute Intensity Bounds: true
    Autocompute Value Bounds: *id001
    Axis: Z
    Channel Name: intensity
    Class: rviz_default_plugins/LaserScan
    Color: 80; 160; 255
    Color Transformer: FlatColor
    Decay Time: 0
    Enabled: true
    Invert Rainbow: false
    Max Color: 255; 255; 255
    Max Intensity: 4096
    Min Color: 0; 0; 0
    Min Intensity: 0
    Name: Boat Laser Range
    Position Transformer: XYZ
    Selectable: true
    Size (Pixels): 3
    Size (m): 0.16
    Style: Flat Squares
    Topic:
      Depth: 5
      Durability Policy: Volatile
      Filter size: 10
      History Policy: Keep Last
      Reliability Policy: Reliable
      Value: /boat/scan_range
    Use Fixed Frame: true
    Use rainbow: true
    Value: true
  - Alpha: 1
    Axes Length: 1
    Axes Radius: 0.10000000149011612
    Class: rviz_default_plugins/Pose
    Color: 40; 255; 80
    Enabled: true
    Head Length: 1
    Head Radius: 0.3499999940395355
    Name: Boat Goal
    Shaft Length: 2
    Shaft Radius: 0.11999999731779099
    Shape: Arrow
    Topic:
      Depth: 5
      Durability Policy: Volatile
      Filter size: 10
      History Policy: Keep Last
      Reliability Policy: Reliable
      Value: /goal_pose
    Value: true
  - Class: rviz_default_plugins/Image
    Enabled: true
    Max Value: 1
    Median window: 5
    Min Value: 0
    Name: Boat Front Camera
    Normalize Range: true
    Topic:
      Depth: 5
      Durability Policy: Volatile
      History Policy: Keep Last
      Reliability Policy: Reliable
      Value: /boat/front_camera
    Value: true
  Enabled: true
  Global Options:
    Background Color: 35; 39; 42
    Fixed Frame: map
    Frame Rate: 30
  Name: root
  Tools:
  - Class: rviz_default_plugins/Interact
    Hide Inactive Objects: true
  - Class: rviz_default_plugins/MoveCamera
  - Class: rviz_default_plugins/Select
  - Class: rviz_default_plugins/FocusCamera
  - Class: rviz_default_plugins/SetGoal
    Topic:
      Depth: 5
      Durability Policy: Volatile
      History Policy: Keep Last
      Reliability Policy: Reliable
      Value: /goal_pose
  - Class: rviz_default_plugins/PublishPoint
    Single click: true
    Topic:
      Depth: 5
      Durability Policy: Volatile
      History Policy: Keep Last
      Reliability Policy: Reliable
      Value: /clicked_point
  Transformation:
    Current:
      Class: rviz_default_plugins/TF
  Value: true
  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Distance: 12.215044975280762
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.05999999865889549
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Focal Point:
        X: 31.91883659362793
        Y: -14.498943328857422
        Z: 15.067658424377441
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.05000000074505806
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.009999999776482582
      Pitch: 0.41500088572502136
      Target Frame: <Fixed Frame>
      Value: Orbit (rviz_default_plugins)
      Yaw: 1.3587325811386108
    Saved: null
Window Geometry:
  Boat Front Camera:
    collapsed: false
  Displays:
    collapsed: false
  Height: 900
  Hide Left Dock: false
  Hide Right Dock: false
  QMainWindow State: 
  Views:
    collapsed: false
  Width: 1400
  X: 690
  Y: 27
