    </model>
    <include>
      <uri>model://simple_boat</uri>
      <name>landing_boat</name>
      <pose>0 0 0.34999999999999998 0 0 0</pose>
    </include>
    <light name='directionallight' type='directional'>
      <pose>3.6650413048508694 0.062467871162392719 2 0 0 0</pose>
      <cast_shadows>true</cast_shadows>
      <intensity>1</intensity>
