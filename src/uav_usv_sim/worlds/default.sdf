          <geometry>
            <cylinder>
              <radius>0.85</radius>
              <length>8.2</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.85 0.83 0.76 1</ambient>
            <diffuse>0.95 0.93 0.84 1</diffuse>
            <specular>0.2 0.2 0.18 1</specular>
          </material>
        </visual>
        <visual name='red_band_lower_visual'>
          <pose>0 0 2.7 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.88</radius>
              <length>0.65</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.55 0.04 0.03 1</ambient>
            <diffuse>0.85 0.06 0.04 1</diffuse>
            <specular>0.15 0.03 0.03 1</specular>
          </material>
        </visual>
        <visual name='red_band_upper_visual'>
          <pose>0 0 5.8 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.88</radius>
              <length>0.65</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.55 0.04 0.03 1</ambient>
            <diffuse>0.85 0.06 0.04 1</diffuse>
            <specular>0.15 0.03 0.03 1</specular>
          </material>
        </visual>
        <visual name='lantern_room_visual'>
          <pose>0 0 8.8 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>1.05</radius>
              <length>0.9</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.95 0.82 0.32 0.85</ambient>
