            <specular>0.18 0.04 0.04 1</specular>
          </material>
        </visual>
        <light name='beacon_light' type='point'>
          <pose>0 0 8.95 0 0 0</pose>
          <cast_shadows>false</cast_shadows>
          <intensity>3</intensity>
          <diffuse>1 0.86 0.35 1</diffuse>
          <specular>1 0.9 0.55 1</specular>
          <attenuation>
            <range>80</range>
